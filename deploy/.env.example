# ── Telegram ─────────────────────────────────────────────────────────────────
BOT_TOKEN=123456789:AABBccDDeeFFggHH-xxxxxxxxxxxxxx
CHAT_ID=-1001234567890
# ID топика "АНОНСЫ ТРЕНИРОВОК" в чате (без неё анонсы результатов не отправятся)
ANNOUNCEMENTS_TOPIC_ID=your_announcements_topic_id_here
# ID топика для опросов по играм (по умолчанию 1282, если не задано)
GAMES_TOPIC_ID=your_games_topic_id_here

# Числовые Telegram ID администраторов через запятую (узнать можно у
# @userinfobot) — только им в личных сообщениях с ботом будет доступна
# команда /admin
ADMIN_USER_IDS=your_telegram_user_id_here

